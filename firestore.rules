rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for Templates
    function isValidTemplate(data) {
      return data.id is string && data.id.size() > 0
        && data.name is string && data.name.size() > 0
        && data.fields is list
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time;
    }

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(templateId) && isValidTemplate(request.resource.data);
      allow update: if isOwner(resource.data.createdBy) 
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.createdBy);
    }

    // Helper for Records
    function isValidRecord(data) {
      return data.templateId is string
        && data.status in ['pending', 'success', 'failed']
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    match /records/{recordId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && isValidId(recordId) && isValidRecord(request.resource.data);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
